<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BUtil.UI.Controls.ViewDecoration"
             IsHitTestVisible="False">
	<Path x:Name="DecorationPath"
	      HorizontalAlignment="Right"
	      VerticalAlignment="Bottom"
	      MaxWidth="300"
	      Margin="0 0 14 14"
	      Stroke="Gray"
	      StrokeThickness="8"
	      StrokeLineCap="Round"
	      Stretch="Uniform" />
</UserControl>

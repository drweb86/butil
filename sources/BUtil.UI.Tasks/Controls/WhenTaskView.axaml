<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:cvm="clr-namespace:BUtil.UI.Controls;assembly=BUtil.UI.Tasks"
             mc:Ignorable="d"
             x:Class="BUtil.UI.Controls.WhenTaskView"
			 x:DataType="cvm:WhenTaskViewModel">
	<Expander HorizontalAlignment="Stretch" IsExpanded="{Binding IsExpanded}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent">
		<Expander.Header>
			<StackPanel Orientation="Horizontal">
				<Image Width="16" Height="16" Source="avares://BUtil.UI/Assets/CrystalClear_EveraldoCoelho_Schedule48x48.png" VerticalAlignment="Center" />
				<TextBlock Text="{Binding LeftMenu_When}" Margin="8 0 0 0" VerticalAlignment="Center" />
			</StackPanel>
		</Expander.Header>
		<StackPanel Spacing="8">
			<Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="8">
				<StackPanel>
					<TextBlock Text="{Binding Days_Field_Choose}" />
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<CheckBox Grid.Column="0" Grid.Row="0" IsChecked="{Binding Monday}" Content="{Binding Days_Monday}" />
						<CheckBox Grid.Column="0" Grid.Row="1" IsChecked="{Binding Tuesday}" Content="{Binding Days_Tuesday}" />
						<CheckBox Grid.Column="0" Grid.Row="2" IsChecked="{Binding Wednesday}" Content="{Binding Days_Wednesday}" />
						<CheckBox Grid.Column="0" Grid.Row="3" IsChecked="{Binding Thursday}" Content="{Binding Days_Thursday}" />
						<CheckBox Grid.Column="1" Grid.Row="0" IsChecked="{Binding Friday}" Content="{Binding Days_Friday}" />
						<CheckBox Grid.Column="1" Grid.Row="1" IsChecked="{Binding Saturday}" Content="{Binding Days_Saturday}" />
						<CheckBox Grid.Column="1" Grid.Row="2" IsChecked="{Binding Sunday}" Content="{Binding Days_Sunday}" />
					</Grid>
					<TextBlock Text="{Binding Time_Field_Hour}" Margin="0 4 0 4" />
					<NumericUpDown Minimum="0" Maximum="23" FormatString="N0" Value="{Binding Hours}" />
					<TextBlock Text="{Binding Time_Field_Minute}" Margin="0 4 0 4" />
					<NumericUpDown Minimum="0" Maximum="59" FormatString="N0" Value="{Binding Minutes}" />
				</StackPanel>
			</Border>
			<Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="8">
				<CheckBox IsChecked="{Binding RunAtLogin}" Content="{Binding RunAtLogin_Label}" />
			</Border>
		</StackPanel>
	</Expander>
</UserControl>

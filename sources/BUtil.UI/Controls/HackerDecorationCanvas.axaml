<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BUtil.UI.Controls.HackerDecorationCanvas"
             IsHitTestVisible="False"
             Width="480" Height="368"
             HorizontalAlignment="Right"
             VerticalAlignment="Bottom"
             Margin="0 0 14 14"
             Opacity="0.95">
    <Canvas Width="480" Height="368" ClipToBounds="True">

        <!-- Binary rain columns are generated in code behind; visible where the photo is transparent -->
        <Canvas x:Name="RainCanvas" Width="480" Height="368" />

        <!-- Soft glow behind the laptop screen -->
        <Ellipse x:Name="GlowEllipse" Canvas.Left="15" Canvas.Top="30" Width="300" Height="300">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#3800E5FF" Offset="0"/>
                    <GradientStop Color="#0000E5FF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Hacker photo with transparent background -->
        <Image Source="/Assets/hacker.png" Width="480" Height="368" Stretch="Uniform"/>

        <!-- Rising glowing motes are generated in code behind -->
        <Canvas x:Name="ParticlesCanvas" Width="480" Height="368" />

    </Canvas>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:cvm="clr-namespace:BUtil.UI.Controls"
             mc:Ignorable="d"
             x:Class="BUtil.UI.Controls.TaskCard"
			 x:DataType="cvm:TaskCardViewModel"
			 CornerRadius="8"
			 BorderThickness="1"
			 Margin="8"
			 Padding="4"
			 BorderBrush="{Binding Foreground}"
			 Background="{Binding Background}"
			 MinWidth="280">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="Auto" />
		</Grid.ColumnDefinitions>

		<StackPanel
			Grid.Column="0"
			Margin="4"
			Orientation="Vertical"
			VerticalAlignment="Stretch"
			HorizontalAlignment="Stretch"
			MaxWidth="{Binding $parent.Bounds.Width}">
			<Grid ColumnDefinitions="*,Auto" Margin="0 0 0 8">
				<Button
					Grid.Column="0"
					Margin="12 3 0 0"
					Padding="0"
					Background="Transparent"
					BorderThickness="0"
					HorizontalAlignment="Left"
					VerticalAlignment="Center"
					Command="{Binding TaskEditCommand}"
					ToolTip.Tip="{Binding Task_Edit}">
					<TextBlock
						Text="{Binding Path=Name}"
						Foreground="{Binding ForegroundWindowFontAccented}"
						TextWrapping="Wrap" />
				</Button>
				<Menu Grid.Column="1" VerticalAlignment="Center" Margin="0 0 0 0">
					<MenuItem Header="⁝">
					<MenuItem Header="{Binding Task_Edit}" Command="{Binding TaskEditCommand}">
						<MenuItem.Icon>
							<Image Width="16" Height="16" Source="/Assets/CrystalClear_EveraldoCoelho_OtherOptions48x48.png" />
						</MenuItem.Icon>
					</MenuItem>

					<MenuItem Header="{Binding Task_Duplicate}" Command="{Binding TaskDuplicateCommand}">
						<MenuItem.Icon>
							<Image Width="16" Height="16" Source="/Assets/CrystalClear_FileNew.png" />
						</MenuItem.Icon>
					</MenuItem>

					<MenuItem Header="{Binding Task_Restore}" Command="{Binding TaskRestoreCommand}">
							<MenuItem.Icon>
								<Image Width="16" Height="16" Source="/Assets/CrystalClear_EveraldoCoelho_Refresh48x48.png" />
							</MenuItem.Icon>
						</MenuItem>

					<MenuItem Header="{Binding Task_Delete}" Command="{Binding TaskDeleteCommand}">
						<MenuItem.Icon>
							<Image Width="16" Height="16" Source="/Assets/www.wefunction.com_FunctionFreeIconSet_cross_48.png" />
						</MenuItem.Icon>
					</MenuItem>

					<MenuItem Header="{Binding Task_OpenLog}" Command="{Binding OpenLogCommand}" IsEnabled="{Binding HasLog}" />
				</MenuItem>
			</Menu>
			</Grid>

			<HyperlinkButton
				Command="{Binding OpenLogCommand}"
				IsVisible="{Binding HasLog}"
				ToolTip.Tip="{Binding Path=OpenLogTooltip}">
				<TextBlock
					Text="{Binding Path=LastLaunchedAt}"
					Foreground="{Binding Path=Foreground}"
					TextWrapping="Wrap"
				/>
			</HyperlinkButton>
			
			<Button
				Background="Transparent"
				BorderBrush="{Binding Foreground}"
				Foreground="{Binding Foreground}"
				BorderThickness="1"
				HorizontalAlignment="Right"
				VerticalAlignment="Center"
				Padding="16 8 16 8"
				CornerRadius="16"
				Command="{Binding TaskLaunchCommand}"
				Content="{Binding Task_Launch}">
			</Button>
		</StackPanel>
	</Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:cvm="clr-namespace:BUtil.UI.Controls"
             xmlns:sfvm="clr-namespace:BUtil.UI.Controls.StorageFields"
             mc:Ignorable="d"
             x:Class="BUtil.UI.Controls.WhereTaskView"
             x:DataType="cvm:WhereTaskViewModel">
	<Expander HorizontalAlignment="Stretch" IsExpanded="False" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent">
		<Expander.Header>
			<StackPanel Orientation="Horizontal">
				<Image Width="16" Height="16" Source="{Binding IconSource}" VerticalAlignment="Center" />
				<TextBlock Text="{Binding Title}" Margin="8 0 0 0" VerticalAlignment="Center" />
			</StackPanel>
		</Expander.Header>
		<StackPanel Spacing="4" Margin="0 4 0 0">

			<!-- Transport protocol -->
			<DockPanel>
				<TextBlock DockPanel.Dock="Left" MinWidth="160" Text="{Binding Field_TransportProtocol}" VerticalAlignment="Center" Margin="0 0 4 0" />
				<ComboBox HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="4 2"
				          ItemsSource="{Binding Providers}"
				          SelectedItem="{Binding SelectedProvider}">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding DisplayName}" />
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
			</DockPanel>

			<!-- Quota (common to all storage types) -->
			<DockPanel>
				<TextBlock DockPanel.Dock="Left" MinWidth="160"
				           Text="{Binding DataStorage_Field_UploadQuota}"
				           ToolTip.Tip="{Binding DataStorage_Field_UploadQuota_Help}"
				           TextDecorations="Underline"
				           VerticalAlignment="Center" Margin="0 0 4 0" />
				<NumericUpDown Minimum="0" Margin="4 2" VerticalAlignment="Center" Value="{Binding Quota}" />
			</DockPanel>

			<!-- Per-storage-type fields — rendered from provider metadata, no XAML changes needed for new types -->
			<ItemsControl ItemsSource="{Binding Fields}">
				<ItemsControl.DataTemplates>

					<DataTemplate x:DataType="sfvm:TextFieldViewModel">
						<DockPanel Margin="0 2">
							<TextBlock DockPanel.Dock="Left" MinWidth="160" Text="{Binding DisplayLabel}" VerticalAlignment="Center" Margin="0 0 4 0" />
							<TextBox Margin="4 0" VerticalAlignment="Center"
							         PlaceholderText="{Binding Descriptor.Placeholder}"
							         Text="{Binding Value}" />
						</DockPanel>
					</DataTemplate>

					<DataTemplate x:DataType="sfvm:PasswordFieldViewModel">
						<DockPanel Margin="0 2">
							<TextBlock DockPanel.Dock="Left" MinWidth="160" Text="{Binding DisplayLabel}" VerticalAlignment="Center" Margin="0 0 4 0" />
							<TextBox Margin="4 0" VerticalAlignment="Center" PasswordChar="*"
							         Text="{Binding Value}" />
						</DockPanel>
					</DataTemplate>

					<DataTemplate x:DataType="sfvm:IntegerFieldViewModel">
						<DockPanel Margin="0 2">
							<TextBlock DockPanel.Dock="Left" MinWidth="160" Text="{Binding DisplayLabel}" VerticalAlignment="Center" Margin="0 0 4 0" />
							<NumericUpDown Margin="4 0" VerticalAlignment="Center"
							               Minimum="{Binding Minimum}"
							               Maximum="{Binding Maximum}"
							               Value="{Binding Value}" />
						</DockPanel>
					</DataTemplate>

					<DataTemplate x:DataType="sfvm:FolderFieldViewModel">
						<DockPanel Margin="0 2">
							<TextBlock DockPanel.Dock="Left" MinWidth="160" Text="{Binding DisplayLabel}" VerticalAlignment="Center" Margin="0 0 4 0" />
							<Button DockPanel.Dock="Right" Content="{Binding BrowseLabel}" VerticalAlignment="Center" Margin="4 0 0 0" Click="FieldBrowseFolderCommand" />
							<TextBox Margin="4 0" VerticalAlignment="Center"
							         PlaceholderText="{Binding Descriptor.Placeholder}"
							         Text="{Binding Value}" />
						</DockPanel>
					</DataTemplate>

					<DataTemplate x:DataType="sfvm:FileFieldViewModel">
						<DockPanel Margin="0 2">
							<TextBlock DockPanel.Dock="Left" MinWidth="160" Text="{Binding DisplayLabel}" VerticalAlignment="Center" Margin="0 0 4 0" />
							<Button DockPanel.Dock="Right" Content="{Binding BrowseLabel}" VerticalAlignment="Center" Margin="4 0 0 0" Click="FieldBrowseFileCommand" />
							<TextBox Margin="4 0" VerticalAlignment="Center"
							         PlaceholderText="{Binding Descriptor.Placeholder}"
							         Text="{Binding Value}" />
						</DockPanel>
					</DataTemplate>

					<DataTemplate x:DataType="sfvm:EnumFieldViewModel">
						<DockPanel Margin="0 2">
							<TextBlock DockPanel.Dock="Left" MinWidth="160" Text="{Binding DisplayLabel}" VerticalAlignment="Center" Margin="0 0 4 0" />
							<ComboBox HorizontalAlignment="Stretch" Margin="4 0" VerticalAlignment="Center"
							          ItemsSource="{Binding DisplayOptions}"
							          SelectedItem="{Binding SelectedDisplay}" />
						</DockPanel>
					</DataTemplate>

				</ItemsControl.DataTemplates>
			</ItemsControl>

			<!-- Mount/unmount scripts (shown only when platform supports script execution) -->
			<Expander IsVisible="{Binding CanLaunchScripts}" IsExpanded="False" HorizontalAlignment="Stretch">
				<Expander.Header>
					<TextBlock Text="{Binding DataStorage_Scripts_Header}" VerticalAlignment="Center" />
				</Expander.Header>
				<StackPanel Spacing="8">
					<TextBlock Text="{Binding DataStorage_Script_Help}" VerticalAlignment="Center" TextWrapping="Wrap" />
					<Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
						<TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DataStorage_Field_ConnectScript}" VerticalAlignment="Center" Margin="0 0 0 4" />
						<TextBox Grid.Row="0" Grid.Column="1" AcceptsReturn="True" Margin="4 0 4 4"
						         PlaceholderText="net use X: \\myserver\myfolder myPassword /user:myUser"
						         Text="{Binding MountScript}" Height="150" MinWidth="200" />
						<Button Grid.Row="0" Grid.Column="2" Content="{Binding Task_Launch}" VerticalAlignment="Center" Margin="0 0 0 4" Click="MountScriptLaunchCommand" />
						<TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DataStorage_Field_DisconnectionScript}" VerticalAlignment="Center" Margin="0 0 0 4" />
						<TextBox Grid.Row="1" Grid.Column="1" AcceptsReturn="True" Margin="4 0 4 4"
						         PlaceholderText="net use X: /delete"
						         Text="{Binding UnmountScript}" Height="150" MinWidth="200" />
						<Button Grid.Row="1" Grid.Column="2" Content="{Binding Task_Launch}" VerticalAlignment="Center" Margin="0 0 0 4" Click="UnmountScriptLaunchCommand" />
					</Grid>
				</StackPanel>
			</Expander>

		</StackPanel>
	</Expander>
</UserControl>
